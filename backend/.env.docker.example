# Database (Docker networking — use container name as host)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/wise_accounts?schema=public"

# JWT
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHARS"
JWT_EXPIRY="15m"

# Server
PORT=3000
CORS_ORIGIN="*"

# AWS
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_KEY"
SES_FROM_EMAIL="support@wiseaccs.com"

# SMS (MSG91)
MSG91_AUTH_KEY="YOUR_MSG91_AUTH_KEY"
MSG91_FLOW_ID=""
SMS_SENDER_ID="WISEACCS"
SMS_TRANSACTIONAL_TYPE="Transactional"
SMS_PROMOTIONAL_TYPE="Promotional"

# SMS (Twilio) - fallback provider
TWILIO_ACCOUNT_SID="YOUR_TWILIO_SID"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_TOKEN"
TWILIO_FROM_NUMBER="+1XXXXXXXXXX"

# Razorpay
RAZORPAY_KEY_ID="YOUR_RAZORPAY_KEY"
RAZORPAY_KEY_SECRET="YOUR_RAZORPAY_SECRET"

# UPI
UPI_ID="payment@upi"
