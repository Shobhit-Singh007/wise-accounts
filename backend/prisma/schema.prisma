generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_ADMIN
  BUSINESS_EDITOR
  BUSINESS_VIEWER
}

enum InvoiceType {
  B2B
  B2C
}

enum InvoiceDirection {
  SALE
  PURCHASE
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  CREDITED
}

enum DocumentType {
  INVOICE
  QUOTATION
  PROFORMA
  DELIVERY_CHALLAN
  JOBWORK
  CREDIT_NOTE
  LETTERHEAD
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  RAZORPAY
  CHEQUE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
  FAILED
}

enum StockMovementType {
  PURCHASE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  RETURN
}

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  name         String
  role         UserRole @default(BUSINESS_ADMIN)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens   RefreshToken[]
  userBusinesses  UserBusiness[]
  createdInvoices Invoice[]       @relation("CreatedBy")
  creditNotes     CreditNote[]    @relation("CreditNoteCreatedBy")
  auditLogs       AuditLog[]
  sentInvites     StaffInvite[]   @relation("InviteSentBy")
  receivedInvites StaffInvite[]   @relation("InviteForUser")
  notifications   Notification[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
}

model UserBusiness {
  id          String   @id @default(uuid())
  userId      String
  businessId  String
  role        UserRole @default(BUSINESS_ADMIN)
  isDefault   Boolean  @default(false)
  permissions Json     @default("[]")
  joinedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  business    Business @relation(fields: [businessId], references: [id])

  @@unique([userId, businessId])
}

model Business {
  id          String   @id @default(uuid())
  name        String
  gstin       String?
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  logoUrl     String?
  settings    Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           UserBusiness[]
  warehouses      Warehouse[]
  customers       Customer[]
  customerGroups  CustomerGroup[]
  categories      Category[]
  products        Product[]
  suppliers       Supplier[]
  invoices        Invoice[]
  payments        Payment[]
  purchaseOrders  PurchaseOrder[]
  auditLogs       AuditLog[]
  staffInvites    StaffInvite[]
  recurringInvoices RecurringInvoice[]
  notifications     Notification[]
}

model Warehouse {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  address     String?
  city        String?
  state       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business       Business       @relation(fields: [businessId], references: [id])
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
}

model CustomerGroup {
  id         String   @id @default(uuid())
  businessId String
  name       String
  discount   Float?
  createdAt  DateTime @default(now())

  business  Business   @relation(fields: [businessId], references: [id])
  customers Customer[]
}

model Customer {
  id          String   @id @default(uuid())
  businessId  String
  groupId     String?
  name        String
  phone       String?
  email       String?
  gstin       String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  creditLimit Float    @default(0)
  balance     Float    @default(0)
  openingBalance Float @default(0)
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business          @relation(fields: [businessId], references: [id])
  group       CustomerGroup?    @relation(fields: [groupId], references: [id])
  invoices    Invoice[]
  payments    Payment[]
  transactions CustomerTransaction[]
  recurringInvoices RecurringInvoice[]

  @@index([businessId])
}

model CustomerTransaction {
  id              String   @id @default(uuid())
  customerId      String
  type            String
  amount          Float
  balanceAfter    Float
  description     String?
  referenceId     String?
  imageUrl        String?
  transactionDate DateTime?
  createdAt       DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model Category {
  id         String   @id @default(uuid())
  businessId String
  name       String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business    Business   @relation(fields: [businessId], references: [id])
  parent      Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryParent")
  products    Product[]
}

model Product {
  id             String   @id @default(uuid())
  businessId     String
  categoryId     String?
  name           String
  sku            String?
  hsnCode        String?
  unit           String   @default("piece")
  sellingPrice   Float    @default(0)
  purchasePrice  Float    @default(0)
  mrp            Float?
  taxRate        Float    @default(0)
  taxType        String   @default("inclusive")
  trackBatch     Boolean  @default(false)
  trackExpiry    Boolean  @default(false)
  lowStockThreshold Int   @default(0)
  imageUrl       String?
  barcode        String?
  isService      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business      Business      @relation(fields: [businessId], references: [id])
  category      Category?     @relation(fields: [categoryId], references: [id])
  stockBatches  StockBatch[]
  invoiceItems   InvoiceItem[]
  purchaseItems  PurchaseOrderItem[]
  stockMovements StockMovement[]

  @@index([businessId])
}

model StockBatch {
  id          String   @id @default(uuid())
  productId   String
  warehouseId String
  batchNo     String?
  quantity    Int      @default(0)
  expiryDate  DateTime?
  purchasePrice Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId, batchNo])
  @@index([productId])
}

model StockMovement {
  id              String            @id @default(uuid())
  productId       String
  warehouseId     String
  batchNo         String?
  type            StockMovementType
  quantity        Int
  referenceId     String?
  referenceType   String?
  notes           String?
  createdAt       DateTime          @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([productId])
}

model Supplier {
  id        String   @id @default(uuid())
  businessId String
  name      String
  phone     String?
  email     String?
  gstin     String?
  address   String?
  city      String?
  state     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business       Business        @relation(fields: [businessId], references: [id])
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
}

model PurchaseOrder {
  id              String   @id @default(uuid())
  businessId      String
  supplierId      String?
  orderNo         String   @unique
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  subtotal        Float    @default(0)
  taxAmount       Float    @default(0)
  discount        Float    @default(0)
  grandTotal      Float    @default(0)
  status          String   @default("PENDING")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business    Business             @relation(fields: [businessId], references: [id])
  supplier    Supplier?            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]

  @@index([businessId])
}

model PurchaseOrderItem {
  id          String @id @default(uuid())
  purchaseOrderId String
  productId   String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  batchNo     String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

model Invoice {
  id          String        @id @default(uuid())
  businessId  String
  customerId  String?
  supplierId  String?
  invoiceNo   String        @unique
  type        InvoiceType   @default(B2C)
  direction   InvoiceDirection @default(SALE)
  invoiceDate DateTime      @default(now())
  dueDate     DateTime?
  subtotal    Float         @default(0)
  taxAmount   Float         @default(0)
  discount    Float         @default(0)
  roundOff    Float         @default(0)
  grandTotal  Float         @default(0)
  paidAmount  Float         @default(0)
  status      InvoiceStatus @default(CONFIRMED)
  notes       String?
  terms       String?
  ewayBillNo  String?
  ewayBillDate   DateTime?
  transporterId  String?
  transporterName String?
  vehicleNo      String?
  distanceKm     Int?
  supplyType     String?   @default("Regular")
  docType        String?   @default("Tax Invoice")
  documentType   DocumentType @default(INVOICE)
  valueOfGoods   Float?
  totalQuantity  Int      @default(0)

  irn            String?
  irnDate        DateTime?
  ackNo          String?
  ackDate        DateTime?
  qrCode         String?

  customerAddress  String?
  customerPhone    String?
  customerState    String?
  placeOfSupply    String?
  reverseCharge    Boolean  @default(false)
  poNo             String?
  poDate           DateTime?
  challanNo        String?
  challanDate      DateTime?
  lrNo             String?
  paymentType      String?
  paymentNote      String?
  cessTotal        Float    @default(0)
  totalInWords     String?

  referenceId String?
  recurringInvoiceId String?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business    Business      @relation(fields: [businessId], references: [id])
  customer    Customer?     @relation(fields: [customerId], references: [id])
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  createdBy   User          @relation("CreatedBy", fields: [createdById], references: [id])
  recurringInvoice RecurringInvoice? @relation(fields: [recurringInvoiceId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
  creditNotes CreditNote[]

  @@index([businessId])
  @@index([customerId])
}

model InvoiceItem {
  id        String @id @default(uuid())
  invoiceId String
  productId String?
  itemName  String
  quantity  Float
  unit      String @default("piece")
  rate      Float
  discount  Float  @default(0)
  taxableValue Float @default(0)
  taxRate   Float  @default(0)
  cgst      Float  @default(0)
  sgst      Float  @default(0)
  igst      Float  @default(0)
  total     Float  @default(0)
  batchNo   String?
  expiryDate DateTime?
  productNote  String?
  cgstRate     Float  @default(0)
  sgstRate     Float  @default(0)
  igstRate     Float  @default(0)
  cessRate     Float  @default(0)
  cessAmount   Float  @default(0)
  serialNo     Int?

  invoice         Invoice         @relation(fields: [invoiceId], references: [id])
  product         Product?        @relation(fields: [productId], references: [id])
  creditNoteItems CreditNoteItem[]

  @@index([invoiceId])
  @@index([productId])
}

model CreditNote {
  id          String   @id @default(uuid())
  invoiceId   String
  creditNoteNo String  @unique
  totalCredit Float    @default(0)
  reason      String?
  createdById String
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  createdBy User   @relation("CreditNoteCreatedBy", fields: [createdById], references: [id])
  items    CreditNoteItem[]

  @@index([invoiceId])
}

model CreditNoteItem {
  id            String @id @default(uuid())
  creditNoteId  String
  invoiceItemId String
  productId     String?
  itemName      String
  quantity      Float
  unit          String @default("piece")
  rate          Float
  discount      Float  @default(0)
  taxableValue  Float  @default(0)
  taxRate       Float  @default(0)
  cgst          Float  @default(0)
  sgst          Float  @default(0)
  igst          Float  @default(0)
  total         Float  @default(0)
  reason        String?

  creditNote  CreditNote  @relation(fields: [creditNoteId], references: [id])
  invoiceItem InvoiceItem @relation(fields: [invoiceItemId], references: [id])
}

model Payment {
  id          String        @id @default(uuid())
  businessId  String
  customerId  String?
  invoiceId   String?
  amount      Float
  method      PaymentMethod
  status      PaymentStatus @default(COMPLETED)
  reference   String?
  notes       String?
  paidAt      DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  business Business  @relation(fields: [businessId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  invoice  Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([businessId])
  @@index([customerId])
}

model RazorpayOrder {
  id          String   @id @default(uuid())
  businessId  String
  invoiceId   String?
  razorpayOrderId String @unique
  amount      Float
  currency    String   @default("INR")
  status      String   @default("CREATED")
  receipt     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model AuditLog {
  id          String   @id @default(uuid())
  businessId  String?
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  business Business? @relation(fields: [businessId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([businessId])
}

model SyncLog {
  id        String     @id @default(uuid())
  deviceId  String
  businessId String
  table     String
  action    String
  entityId  String
  payload   Json
  status    SyncStatus @default(PENDING)
  errorMsg  String?
  createdAt DateTime   @default(now())
  syncedAt  DateTime?

  @@index([businessId])
}

model StaffInvite {
  id           String   @id @default(uuid())
  businessId   String
  phone        String
  email        String?
  name         String?
  permissions  Json     @default("[]")
  role         UserRole @default(BUSINESS_EDITOR)
  token        String   @unique
  invitedById  String
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime @default(now())

  business  Business @relation(fields: [businessId], references: [id])
  inviter   User     @relation("InviteSentBy", fields: [invitedById], references: [id])
  invitee   User?    @relation("InviteForUser", fields: [inviteeId], references: [id])
  inviteeId String?

  @@index([businessId])
  @@index([token])
  @@index([phone])
}

model RecurringInvoice {
  id              String   @id @default(uuid())
  businessId      String
  customerId      String?
  templateName    String?
  frequency       String   // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  nextRunDate     DateTime
  lastRunDate     DateTime?
  isActive        Boolean  @default(true)
  itemCount       Int      @default(0)
  totalAmount     Float    @default(0)
  notes           String?
  items           Json     // Store invoice items template as JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  invoices Invoice[]

  @@index([businessId])
  @@index([nextRunDate])
}

model ReconciliationLog {
  id              String   @id @default(uuid())
  businessId      String
  paymentId       String
  invoiceId       String?
  matchedAmount   Float
  matchType       String   // EXACT, PARTIAL, UNMATCHED
  reference       String?
  notes           String?
  reconciledAt    DateTime @default(now())

  @@index([businessId])
  @@index([paymentId])
}

model Notification {
  id          String   @id @default(uuid())
  businessId  String
  userId      String?
  type        String   // PAYMENT_RECEIVED, PAYMENT_OVERDUE, INVOICE_SHARED, LOW_STOCK, STAFF_INVITE, GENERAL
  title       String
  message     String
  data        Json?    // { invoiceId, customerId, paymentId, etc. }
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([businessId])
  @@index([userId])
  @@index([businessId, isRead])
}
